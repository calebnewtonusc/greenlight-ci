# GreenLight CI — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token (needs: repo, read:org, workflow scopes)
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Anthropic API key (for Claude synthesis fallback when vLLM is not available)
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# vLLM API key (any secret string — authenticates your vLLM synthesis servers)
VLLM_API_KEY=your_vllm_secret_here

# ── Optional: Monitoring ───────────────────────────────────────────────────────

# Weights & Biases (training metrics dashboard)
# https://wandb.ai/settings
WANDB_API_KEY=

# HuggingFace token (for uploading model weights post-training)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Optional: CI Platform Integrations ────────────────────────────────────────

# CircleCI API token (for CircleCI log fetching)
CIRCLECI_TOKEN=

# Jenkins URL and credentials (for Jenkins log fetching)
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=

# ── Optional: Infrastructure ──────────────────────────────────────────────────

# Redis connection URL (default: local Redis)
REDIS_URL=redis://localhost:6379/0

# Sandbox Docker registry (default: Docker Hub)
SANDBOX_REGISTRY=docker.io

# vLLM server URLs (comma-separated, for multi-instance synthesis)
VLLM_URLS=http://localhost:8001,http://localhost:8002

# ── Model Paths ───────────────────────────────────────────────────────────────

# Path to trained GreenLight CI model (after training completes)
GREENLIGHT_MODEL_PATH=./checkpoints/greenlight-final

# Override base model (default: Qwen/Qwen2.5-7B-Coder-Instruct)
BASE_MODEL=Qwen/Qwen2.5-7B-Coder-Instruct
